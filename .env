# Wake-on-LAN Manager Configuration
# Copy this file to .env and modify values as needed
# Example configuration with common settings

# Device configuration file path (relative to app directory)
DEVICES_FILE=devices.json

# Flask server settings
# FLASK_HOST determines which network interface to listen on
# 0.0.0.0 = all interfaces (recommended for reverse proxy)
# 127.0.0.1 = localhost only
FLASK_HOST=0.0.0.0

# FLASK_PORT is the port the app listens on
FLASK_PORT=5000

# FLASK_DEBUG enables/disables debug mode (use false in production!)
FLASK_DEBUG=false

# Ping/connectivity settings
# PING_TIMEOUT is how long to wait for a ping response (seconds)
PING_TIMEOUT=2

# WOL cooldown duration (in minutes)
# Time to wait after sending WOL before allowing another WOL send to same host
# Prevents accidental duplicate sends while machine is booting
WOL_COOLDOWN_MINUTES=2
